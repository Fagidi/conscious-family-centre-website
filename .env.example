# ── Sanity CMS ────────────────────────────────────────────────
# Create a project at https://sanity.io/manage, then fill these in.
# The site builds with curated fallback content when unset; Sanity takes
# over field-by-field as documents are published.
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2025-01-01"
# Server-only — Editor token. Required for camp registrations, enquiries,
# tour bookings, and webhook fulfilment to write to Sanity.
SANITY_WRITE_TOKEN=""

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://consciousfamilycentre.com"

# ── Payments (gateway-agnostic) ───────────────────────────────
# Default gateway: "paystack" or "flutterwave".
PAYMENT_PROVIDER="paystack"
# Paystack — https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=""
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""
# Flutterwave — https://dashboard.flutterwave.com/settings/apis
FLUTTERWAVE_SECRET_KEY=""
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=""
FLUTTERWAVE_WEBHOOK_HASH=""

# ── Notifications (optional; no-ops until set) ────────────────
RESEND_API_KEY=""
NOTIFY_FROM_EMAIL="hello@consciousfamilycentre.com"
CONTACT_NOTIFY_EMAIL="hello@consciousfamilycentre.com"
